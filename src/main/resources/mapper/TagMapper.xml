<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sy.course_system.mapper.TagMapper">

    <!-- listEnabledTagOptionsByIds --> 

    <select id="listEnabledTagOptionsByIds">
        SELECT id, name, type
        FROM tag
        WHERE id IN
        <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
            #{tagId}
        </foreach>
        AND status = 1
        ORDER BY type, name
    </select>
</mapper>